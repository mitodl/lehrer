# Standalone Tiltfile for lehrer local dev environment.
#
# Usage:
#   cd local-dev && tilt up
#   cd local-dev && tilt up -- --deployment-config ../deployments/mit-ol --mfe-hot-reload
#
# Prerequisites: run scripts/setup.sh first to create the k3d cluster and bootstrap secrets.

config.define_string(
    "deployment-config",
    usage="Path to deployment config directory (default: ../deployments/generic)",
)
config.define_string(
    "release-name",
    usage="Open edX release name matching pip_package_lists subdirectory (default: master)",
)
config.define_string(
    "deployment-name",
    usage="Deployment name matching pip_package_lists filename (default: generic)",
)
config.define_string(
    "settings-namespace",
    usage="Django settings namespace for assets/i18n modules (default: production)",
)
config.define_bool(
    "mfe-hot-reload",
    usage="Also start watch_site hot-reload dev servers for MFEs (default: false)",
)

cfg = config.parse()

# ---- Globals consumed by lehrer-core.star ----

LEHRER_DEPLOY_CONFIG   = cfg.get("deployment-config", config.main_dir + "/../deployments/generic")
LEHRER_REGISTRY        = "localhost:5100"               # host-side push (k3d maps this)
LEHRER_REGISTRY_K8S    = "k3d-lehrer-registry:5000"     # cluster-side pull
LEHRER_REDIS_HOST      = "redis-master.openedx.svc.cluster.local"
LEHRER_OPENSEARCH_HOST = "opensearch-cluster-master.openedx.svc.cluster.local"
LEHRER_NAMESPACE       = "openedx"
LEHRER_MANAGE_INFRA    = True
LEHRER_MYSQL_MANAGED   = True
LEHRER_MONGO_MANAGED   = True
LEHRER_INGRESS         = "traefik"
LEHRER_MFE_HOT_RELOAD  = cfg.get("mfe-hot-reload", False)
LEHRER_NOTES_REPO      = "https://github.com/openedx/edx-notes-api"
LEHRER_HELM_OVERRIDE_DIR = ""  # no override — use lehrer/local-dev/helm/
LEHRER_LOCAL_DEV_DIR   = config.main_dir
LEHRER_LMS_BASE_URL    = "http://localhost:8000"
LEHRER_CMS_BASE_URL    = "http://localhost:8010"
LEHRER_NOTES_PUBLIC_URL = "http://localhost:8001"
LEHRER_APPLY_PLATFORM_CONFIGMAPS = True

LEHRER_RELEASE_NAME    = cfg.get("release-name", "master")
LEHRER_DEPLOY_NAME     = cfg.get("deployment-name", "generic")
LEHRER_SETTINGS_NS     = cfg.get("settings-namespace", "production")

include("./lehrer-core.star")
